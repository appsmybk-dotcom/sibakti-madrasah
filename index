<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>SIBAKTI Madrasah</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config={theme:{extend:{colors:{kemenag:{green:"#006B3F",dark:"#063B2A",gold:"#D4AF37"}},boxShadow:{soft:"0 18px 60px rgba(15,23,42,.14)"}}}}
  </script>
  <style>
    :root{--primary:#006B3F;--dark:#063B2A;--gold:#D4AF37;--bg-image:none;--overlay:.82}
    .hidden-view{display:none!important}.theme-primary{background:var(--primary)}.theme-dark{background:var(--dark)}.theme-gold{background:var(--gold)}.text-primary{color:var(--primary)}
    .glass{background:rgba(255,255,255,.86);backdrop-filter:blur(18px)}
    .kemenag-bg{background:linear-gradient(rgba(6,59,42,var(--overlay)),rgba(6,59,42,var(--overlay))),var(--bg-image),radial-gradient(circle at 20% 10%,rgba(212,175,55,.30),transparent 25%),radial-gradient(circle at 90% 20%,rgba(16,185,129,.22),transparent 28%),linear-gradient(135deg,var(--dark),var(--primary),#0f172a);background-size:cover,cover,auto,auto,auto;background-position:center;background-attachment:fixed}
    .pattern{background-image:radial-gradient(circle at 1px 1px,rgba(212,175,55,.20) 1px,transparent 0);background-size:24px 24px}
    @media print{.no-print{display:none!important}body{background:white!important}}
  </style>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
  <div id="loading" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/60 backdrop-blur-sm"><div class="rounded-3xl bg-white p-6 shadow-soft flex items-center gap-4"><div class="h-10 w-10 animate-spin rounded-full border-4 border-emerald-100 border-t-emerald-700"></div><div><p class="font-black">Memproses...</p><p class="text-sm text-slate-500">Mohon tunggu.</p></div></div></div>
  <div id="toast" class="fixed bottom-5 left-1/2 z-[110] hidden -translate-x-1/2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white shadow-soft"></div>

  <main id="authView" class="kemenag-bg relative min-h-screen overflow-hidden p-4">
    <div class="absolute inset-0 pattern opacity-70"></div>
    <section class="relative mx-auto flex min-h-screen max-w-7xl items-center">
      <div class="grid w-full gap-6 lg:grid-cols-[1.1fr_.9fr]">
        <div class="rounded-[2rem] border border-white/15 bg-white/10 p-7 text-white shadow-soft md:p-10">
          <div class="inline-flex items-center gap-3 rounded-full border border-yellow-300/25 bg-white/10 px-4 py-2 text-sm font-semibold"><span class="h-2.5 w-2.5 rounded-full bg-yellow-300"></span>Kementerian Agama Republik Indonesia</div>
          <div class="mt-8 flex items-center gap-4"><div class="flex h-20 w-20 items-center justify-center rounded-[1.5rem] border border-yellow-300/25 bg-white/10 text-4xl font-black text-yellow-200">S</div><div><p class="text-sm font-bold uppercase tracking-[.32em] text-yellow-200">SIBAKTI</p><h1 class="text-4xl font-black tracking-tight md:text-6xl">Madrasah</h1></div></div>
          <p id="loginSubtitle" class="mt-5 max-w-2xl text-lg leading-relaxed text-emerald-50">Sistem Bimbingan dan Konseling Terintegrasi Nasional untuk madrasah.</p>
          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-3xl font-black text-yellow-200">01</p><p class="mt-1 text-sm text-emerald-50">Superadmin</p></div>
            <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-3xl font-black text-yellow-200">02</p><p class="mt-1 text-sm text-emerald-50">Guru BK</p></div>
            <div class="rounded-3xl border border-white/10 bg-white/10 p-5"><p class="text-3xl font-black text-yellow-200">03</p><p class="mt-1 text-sm text-emerald-50">Siswa</p></div>
          </div>
        </div>

        <div class="glass rounded-[2rem] p-6 shadow-soft md:p-8">
          <div id="loginPanel">
            <div class="flex items-center gap-4"><div class="flex h-14 w-14 items-center justify-center rounded-2xl theme-primary text-2xl font-black text-white ring-4 ring-yellow-300/20">S</div><div><h2 class="text-2xl font-black">Masuk SIBAKTI</h2><p class="text-sm text-slate-500">Masuk sesuai role akun.</p></div></div>
            <form id="loginForm" class="mt-7 space-y-4">
              <label class="block"><span class="text-sm font-bold text-slate-700">Username</span><input name="username" required autocomplete="username" class="mt-1 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none focus:ring-4 focus:ring-emerald-100" placeholder="superadmin"></label>
              <label class="block"><span class="text-sm font-bold text-slate-700">Password</span><input name="password" type="password" required autocomplete="current-password" class="mt-1 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 outline-none focus:ring-4 focus:ring-emerald-100" placeholder="••••••••"></label>
              <button class="w-full rounded-2xl theme-primary px-5 py-3 font-black text-white hover:opacity-95">Masuk Aplikasi</button>
            </form>
            <button id="goRegisterBtn" class="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-5 py-3 font-black hover:bg-slate-50">Daftar Akun Baru</button>
          </div>
          <div id="registerPanel" class="hidden-view">
            <h2 class="text-2xl font-black">Registrasi Akun</h2><p class="mt-1 text-sm text-slate-500">Akun baru menunggu verifikasi.</p>
            <form id="registerForm" class="mt-6 grid gap-4 md:grid-cols-2">
              <label class="block md:col-span-2"><span class="text-sm font-bold">Nama Lengkap</span><input name="nama" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block"><span class="text-sm font-bold">Email</span><input name="email" type="email" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block"><span class="text-sm font-bold">No HP</span><input name="noHp" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block"><span class="text-sm font-bold">Role Diminta</span><select name="requestedRole" class="mt-1 w-full rounded-2xl border px-4 py-3"><option value="GURU_BK">Guru BK</option><option value="SISWA">Siswa</option></select></label>
              <label class="block"><span class="text-sm font-bold">NISN jika Siswa</span><input name="nisn" maxlength="10" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block md:col-span-2"><span class="text-sm font-bold">Madrasah</span><input name="madrasah" value="MTsN 3 Bandung" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block"><span class="text-sm font-bold">Username</span><input name="username" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <label class="block"><span class="text-sm font-bold">Password</span><input name="password" type="password" minlength="8" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
              <button class="md:col-span-2 rounded-2xl theme-primary px-5 py-3 font-black text-white hover:opacity-95">Daftar</button>
            </form>
            <button id="goLoginBtn" class="mt-4 w-full rounded-2xl border bg-white px-5 py-3 font-black">Kembali ke Login</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <main id="appView" class="hidden-view min-h-screen bg-slate-100">
    <div class="flex min-h-screen">
      <aside id="sidebar" class="no-print fixed inset-y-0 left-0 z-40 w-80 -translate-x-full border-r border-white/10 theme-dark text-white transition md:static md:translate-x-0">
        <div class="border-b border-white/10 p-5"><div class="flex items-center gap-3"><div class="flex h-12 w-12 items-center justify-center rounded-2xl theme-gold font-black text-slate-950">S</div><div><p class="text-xs uppercase tracking-[.25em] text-yellow-200">SIBAKTI</p><h2 class="text-lg font-black">Madrasah</h2></div></div></div>
        <nav id="sidebarNav" class="h-[calc(100vh-160px)] space-y-2 overflow-y-auto p-3"></nav>
        <div class="absolute bottom-0 left-0 right-0 border-t border-white/10 p-4 text-xs text-emerald-50"><p class="font-black">Kementerian Agama RI</p><p id="sidebarRoleText" class="mt-1 text-yellow-200">Role: -</p></div>
      </aside>
      <section class="min-w-0 flex-1">
        <header class="no-print sticky top-0 z-30 border-b border-slate-200 bg-white/90 backdrop-blur-xl">
          <div class="flex items-center justify-between gap-4 px-4 py-4 md:px-8">
            <div class="flex min-w-0 items-center gap-3"><button id="menuBtn" class="rounded-2xl theme-dark px-3 py-2 font-black text-white md:hidden">☰</button><div class="min-w-0"><h1 id="pageTitle" class="truncate text-xl font-black md:text-2xl">Dashboard</h1><p id="userInfo" class="truncate text-sm text-slate-500">-</p></div></div>
            <div class="flex items-center gap-2"><button id="refreshBtn" class="rounded-2xl border bg-white px-4 py-2 font-black hover:bg-slate-50">Refresh</button><button id="logoutBtn" class="rounded-2xl theme-dark px-4 py-2 font-black text-white hover:opacity-95">Keluar</button></div>
          </div>
        </header>
        <div class="p-4 md:p-8"><section id="page"></section></div>
      </section>
    </div>
  </main>

  <div id="studentModal" class="fixed inset-0 z-50 hidden overflow-y-auto bg-slate-950/70 p-4 backdrop-blur-sm">
    <div class="mx-auto my-8 max-w-6xl rounded-[2rem] bg-white p-6 shadow-soft">
      <div class="flex items-center justify-between border-b pb-4"><div><h3 class="text-2xl font-black">Form Data Siswa</h3><p class="text-sm text-slate-500">NISN wajib 10 digit.</p></div><button id="closeStudentModalBtn" class="rounded-2xl bg-slate-100 px-4 py-2 font-black">✕</button></div>
      <form id="studentForm" class="mt-6 grid gap-4 md:grid-cols-3">
        <input type="hidden" name="StudentID">
        <label><span class="text-sm font-bold">Madrasah</span><input name="Madrasah" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">NISN *</span><input name="NISN" maxlength="10" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">NIS</span><input name="NIS" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label class="md:col-span-2"><span class="text-sm font-bold">Nama Lengkap *</span><input name="NamaLengkap" required class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">JK</span><select name="JK" class="mt-1 w-full rounded-2xl border px-4 py-3"><option value="">Pilih</option><option value="L">Laki-laki</option><option value="P">Perempuan</option></select></label>
        <label><span class="text-sm font-bold">Kelas</span><input name="Kelas" placeholder="7A" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">Rombel</span><input name="Rombel" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">Jurusan</span><input name="Jurusan" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label class="md:col-span-3"><span class="text-sm font-bold">Alamat</span><textarea name="Alamat" rows="2" class="mt-1 w-full rounded-2xl border px-4 py-3"></textarea></label>
        <label><span class="text-sm font-bold">No HP</span><input name="NoHP" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">Email</span><input name="Email" type="email" class="mt-1 w-full rounded-2xl border px-4 py-3"></label>
        <label><span class="text-sm font-bold">Status</span><select name="Status" class="mt-1 w-full rounded-2xl border px-4 py-3"><option>Aktif</option><option>Pindah</option><option>Lulus</option><option>Nonaktif</option></select></label>
        <div class="md:col-span-3 flex justify-end gap-3 pt-4"><button type="button" id="cancelStudentBtn" class="rounded-2xl border px-5 py-3 font-black">Batal</button><button class="rounded-2xl theme-primary px-5 py-3 font-black text-white">Simpan Data</button></div>
      </form>
    </div>
  </div>

  <script>
    const API_URL="https://sibakti-madrasah-bridge.appsmybk.workers.dev/api";
    const DEFAULT_APPEARANCE={appName:"SIBAKTI Madrasah Nasional",primaryColor:"#006B3F",secondaryColor:"#063B2A",accentColor:"#D4AF37",backgroundMode:"gradient",backgroundImageUrl:"",overlayOpacity:.82,loginSubtitle:"Sistem Bimbingan dan Konseling Terintegrasi Nasional"};
    const state={token:localStorage.getItem("sibakti_token")||"",user:null,students:[],currentPage:"dashboard",appearance:DEFAULT_APPEARANCE};
    const $=s=>document.querySelector(s),$$=s=>Array.from(document.querySelectorAll(s));
    const MENUS={SUPERADMIN:[["dashboard","🏠","Dashboard Nasional"],["students","👥","Data Siswa Nasional"],["accounts","✅","Verifikasi Akun"],["portfolio","📁","Portofolio Nasional"],["monitoring","📡","Monitoring Nasional"],["evaluation","📊","Rekap & Laporan"],["settings","⚙️","Pengaturan Sistem"]],GURU_BK:[["dashboard","🏠","Dashboard Guru BK"],["students","👥","Data Siswa Binaan"],["portfolio","📁","Portofolio Siswa"],["planning","🧭","Perencanaan"],["implementation","📝","Pelaksanaan"],["monitoring","📡","Monitoring"],["evaluation","📊","Evaluasi"],["settings","⚙️","Pengaturan"]],SISWA:[["studentHome","🏠","Beranda"],["students","👤","Profil Saya"],["portfolio","📁","Portofolio Saya"],["assessment","🧩","Asesmen Saya"],["career","🎓","Studi & Karier"],["recommendation","💬","Rekomendasi BK"],["settings","⚙️","Pengaturan Akun"]]};
    function role(){return String(state.user?.Role||"SISWA").toUpperCase()}function esc(v){return String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;")}function formObj(f){return Object.fromEntries(new FormData(f).entries())}function loading(on){$("#loading").classList.toggle("hidden",!on);$("#loading").classList.toggle("flex",on)}function toast(m){const e=$("#toast");e.textContent=m;e.classList.remove("hidden");clearTimeout(window.__t);window.__t=setTimeout(()=>e.classList.add("hidden"),3500)}
    async function api(action,data={},extra={}){const r=await fetch(API_URL,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({action,data,token:state.token,...extra})});const j=await r.json().catch(()=>({success:false,message:"Response server tidak valid."}));if(!j.success)throw new Error(j.message||"Terjadi kesalahan.");return j}
    function applyAppearance(a){state.appearance={...DEFAULT_APPEARANCE,...(a||{})};document.documentElement.style.setProperty("--primary",state.appearance.primaryColor);document.documentElement.style.setProperty("--dark",state.appearance.secondaryColor);document.documentElement.style.setProperty("--gold",state.appearance.accentColor);document.documentElement.style.setProperty("--overlay",String(state.appearance.overlayOpacity??.82));if(state.appearance.backgroundMode==="image"&&state.appearance.backgroundImageUrl)document.documentElement.style.setProperty("--bg-image",`url("${state.appearance.backgroundImageUrl.replaceAll('"',"%22")}")`);else document.documentElement.style.setProperty("--bg-image","none");document.title=state.appearance.appName||"SIBAKTI Madrasah";$("#loginSubtitle").textContent=state.appearance.loginSubtitle||DEFAULT_APPEARANCE.loginSubtitle}
    async function loadAppearance(){try{const r=await api("getPublicAppearance");applyAppearance(r.appearance)}catch(e){applyAppearance(DEFAULT_APPEARANCE)}}
    function showAuth(){$("#authView").classList.remove("hidden-view");$("#appView").classList.add("hidden-view")}function showApp(){$("#authView").classList.add("hidden-view");$("#appView").classList.remove("hidden-view");$("#userInfo").textContent=`${state.user?.Nama||"Pengguna"} • ${role()} • ${state.user?.Madrasah||"-"}`;$("#sidebarRoleText").textContent=`Role: ${role()}`;renderSidebar()}
    function renderSidebar(){const list=MENUS[role()]||MENUS.SISWA;$("#sidebarNav").innerHTML=list.map(([p,i,l])=>`<button data-page="${p}" class="navBtn flex w-full items-center gap-3 rounded-2xl px-4 py-3 text-left font-bold hover:bg-white/10 ${state.currentPage===p?"bg-white/10":""}"><span>${i}</span><span>${l}</span></button>`).join("");$$(".navBtn").forEach(b=>b.onclick=()=>setPage(b.dataset.page))}
    function setPage(p){state.currentPage=p;$("#pageTitle").textContent={dashboard:"Dashboard",students:"Data Siswa",accounts:"Verifikasi Akun",portfolio:"Portofolio",planning:"Perencanaan",implementation:"Pelaksanaan",monitoring:"Monitoring",evaluation:"Evaluasi",settings:"Pengaturan",studentHome:"Beranda Siswa",assessment:"Asesmen Saya",career:"Studi & Karier",recommendation:"Rekomendasi BK"}[p]||"SIBAKTI";renderSidebar();$("#sidebar").classList.add("-translate-x-full");if(p==="dashboard")return renderDashboard();if(p==="students")return renderStudents();if(p==="accounts")return renderAccounts();if(p==="portfolio")return renderPortfolio();if(p==="settings")return renderSettings();if(p==="studentHome")return renderStudentHome();if(p==="planning")return renderModule("Perencanaan BK",["Analisis Kebutuhan","Asesmen Awal","Program Tahunan","Program Semester","RPL BK","Action Plan BK"]);if(p==="implementation")return renderModule("Pelaksanaan BK",["Jurnal BK","Bimbingan Klasikal","Konseling Individual","Konseling Kelompok","Home Visit","Alih Tangan Kasus"]);if(p==="monitoring")return renderModule("Monitoring",["Monitoring Siswa","Monitoring Portofolio","Monitoring Kasus","Early Warning","Tindak Lanjut"]);if(p==="evaluation")return renderModule("Evaluasi",["Evaluasi Proses","Evaluasi Hasil","Evaluasi Program","Laporan PDF/Excel"]);if(p==="assessment")return renderModule("Asesmen Saya",["ITP/ATP","DCM","AUM","VAK","RIASEC","Sosiometri"]);if(p==="career")return renderModule("Studi Lanjut & Karier",["Rencana SMA/MA/SMK","Rencana PT/Prodi","Rencana Karier","Rekomendasi Jurusan"]);if(p==="recommendation")return renderRecommendation()}
    function metric(l,v,i){return`<div class="rounded-[2rem] bg-white p-5 shadow-soft"><div class="flex justify-between"><p class="text-sm font-bold text-slate-500">${l}</p><span class="text-2xl">${i}</span></div><p class="mt-3 text-4xl font-black">${v}</p></div>`}
    async function renderDashboard(){$("#page").innerHTML=`<div class="rounded-[2rem] theme-dark p-6 text-white shadow-soft md:p-8"><p class="text-sm font-bold uppercase tracking-[.25em] text-yellow-200">${role()==="SUPERADMIN"?"Dashboard Nasional":role()==="GURU_BK"?"Dashboard Guru BK":"Beranda Siswa"}</p><h2 class="mt-3 text-3xl font-black md:text-5xl">${esc(state.appearance.appName)}</h2><p class="mt-4 text-emerald-50">${esc(state.appearance.loginSubtitle)}</p></div><div id="metrics" class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-5">${metric("Memuat","...","⏳")}</div><div class="mt-6 rounded-[2rem] bg-white p-6 shadow-soft"><h3 class="text-xl font-black">Ringkasan Data</h3><div id="dashTable" class="mt-4 overflow-x-auto"></div></div>`;try{const r=await api("dashboard"),c=r.data?.counts||{};$("#metrics").innerHTML=[metric(role()==="SUPERADMIN"?"Total Siswa Nasional":"Siswa Binaan",c.students||0,"👥"),metric("Siswa Aktif",c.activeStudents||0,"✅"),metric("Laki-laki",c.male||0,"👦"),metric("Perempuan",c.female||0,"👧"),metric("Akun Pending",c.pendingUsers||0,"⏳")].join("");$("#dashTable").innerHTML=studentTable(r.data?.recentStudents||[],false)}catch(e){toast(e.message)}}
    async function loadStudents(){const r=await api("listStudents",{}, {filters:{}});state.students=r.rows||[];return state.students}
    async function renderStudents(){$("#page").innerHTML=`<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">${role()==="SISWA"?"Profil":"Data Siswa"}</p><h2 class="mt-1 text-3xl font-black">${role()==="SISWA"?"Profil Saya":role()==="SUPERADMIN"?"Data Siswa Nasional":"Data Siswa Binaan"}</h2><p class="mt-1 text-slate-500">Data siswa terhubung ke portofolio.</p></div>${role()==="SISWA"?"":`<button id="addStudentBtn" class="rounded-2xl theme-primary px-5 py-3 font-black text-white">+ Tambah Siswa</button>`}</div><div class="mt-5 overflow-hidden rounded-[2rem] bg-white shadow-soft"><div id="studentsTable" class="overflow-x-auto"></div></div>`;if(role()!=="SISWA")$("#addStudentBtn").onclick=()=>openStudentModal({});try{const rows=await loadStudents();$("#studentsTable").innerHTML=rows.length?studentTable(rows,true):`<div class="p-6 text-sm text-slate-500">Belum ada data siswa.</div>`;$$(".editStudentBtn").forEach(b=>b.onclick=()=>openStudentModal(state.students.find(x=>String(x.StudentID)===String(b.dataset.id))||{}));$$(".portfolioBtn").forEach(b=>b.onclick=()=>setPage("portfolio"))}catch(e){toast(e.message)}}
    function studentTable(rows,actions){if(!rows.length)return`<div class="rounded-2xl bg-slate-50 p-5 text-sm text-slate-500">Belum ada data.</div>`;return`<table class="min-w-full text-sm"><thead class="bg-slate-50 text-left"><tr><th class="p-3">NISN</th><th class="p-3">Nama</th><th class="p-3">JK</th><th class="p-3">Kelas</th><th class="p-3">Madrasah</th><th class="p-3">Status</th>${actions?'<th class="p-3">Aksi</th>':""}</tr></thead><tbody>${rows.map(r=>`<tr class="border-t hover:bg-slate-50"><td class="p-3 font-black">${esc(r.NISN||"-")}</td><td class="p-3">${esc(r.NamaLengkap||"-")}</td><td class="p-3">${esc(r.JK||"-")}</td><td class="p-3">${esc(r.Kelas||"-")}</td><td class="p-3">${esc(r.Madrasah||"-")}</td><td class="p-3">${esc(r.Status||"-")}</td>${actions?`<td class="p-3"><div class="flex gap-2"><button class="portfolioBtn rounded-xl bg-emerald-700 px-3 py-2 text-xs font-black text-white" data-id="${esc(r.StudentID)}">Portofolio</button><button class="editStudentBtn rounded-xl bg-slate-950 px-3 py-2 text-xs font-black text-white" data-id="${esc(r.StudentID)}">Edit</button></div></td>`:""}</tr>`).join("")}</tbody></table>`}
    async function renderAccounts(){$("#page").innerHTML=`<div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">Superadmin</p><h2 class="mt-1 text-3xl font-black">Verifikasi Akun</h2><p class="mt-1 text-slate-500">Setujui atau tolak akun baru.</p></div><div class="mt-5 rounded-[2rem] bg-white shadow-soft overflow-hidden"><div id="pendingTable"></div></div>`;try{const r=await api("listPendingUsers"),rows=r.rows||[];if(!rows.length){$("#pendingTable").innerHTML=`<div class="p-6 text-sm text-slate-500">Tidak ada akun pending.</div>`;return}$("#pendingTable").innerHTML=`<table class="min-w-full text-sm"><thead class="bg-slate-50 text-left"><tr><th class="p-3">Nama</th><th class="p-3">Username</th><th class="p-3">Email</th><th class="p-3">Madrasah</th><th class="p-3">Aksi</th></tr></thead><tbody>${rows.map(u=>`<tr class="border-t"><td class="p-3 font-bold">${esc(u.Nama)}</td><td class="p-3">${esc(u.Username)}</td><td class="p-3">${esc(u.Email)}</td><td class="p-3">${esc(u.Madrasah)}</td><td class="p-3"><button class="verifyBtn rounded-xl bg-emerald-700 px-3 py-2 text-xs font-black text-white" data-id="${esc(u.UserID)}" data-ok="true">Setujui</button> <button class="verifyBtn rounded-xl bg-red-600 px-3 py-2 text-xs font-black text-white" data-id="${esc(u.UserID)}" data-ok="false">Tolak</button></td></tr>`).join("")}</tbody></table>`;$$(".verifyBtn").forEach(b=>b.onclick=async()=>{try{loading(true);const res=await api("verifyUser",{}, {userId:b.dataset.id,approved:b.dataset.ok==="true"});toast(res.message);renderAccounts()}catch(e){toast(e.message)}finally{loading(false)}})}catch(e){toast(e.message)}}
    function renderPortfolio(){const tabs=["Profil","Akademik","Prestasi","Organisasi","Ekstrakurikuler","Sertifikat","Karya","Asesmen","Layanan BK","Perkembangan","Studi Lanjut","Karier","Rekomendasi","Dokumen"];$("#page").innerHTML=`<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">Portofolio Terintegrasi</p><h2 class="mt-1 text-3xl font-black">${role()==="SISWA"?"Portofolio Saya":"Portofolio Siswa"}</h2><p class="mt-1 text-slate-500">Profil, akademik, prestasi, sertifikat, karya, asesmen, layanan BK, studi lanjut, dan karier.</p></div><button onclick="window.print()" class="rounded-2xl border bg-white px-5 py-3 font-black">Cetak</button></div><div class="mt-5 rounded-[2rem] bg-white p-6 shadow-soft"><div class="flex gap-2 overflow-x-auto pb-2">${tabs.map((t,i)=>`<button class="portTab whitespace-nowrap rounded-2xl ${i===0?"theme-primary text-white":"border bg-white"} px-4 py-2 text-sm font-black" data-tab="${t}">${t}</button>`).join("")}</div><div id="portfolioContent" class="mt-5"></div></div>`;const show=t=>$("#portfolioContent").innerHTML=`<div class="rounded-3xl bg-slate-50 p-6"><h3 class="text-2xl font-black">${esc(t)}</h3><p class="mt-2 text-sm text-slate-500">Data ${esc(t)} siap dihubungkan dengan sheet portofolio dan validasi Guru BK.</p><button class="mt-5 rounded-2xl theme-primary px-4 py-2 font-black text-white" onclick="toast('Form tambah ${esc(t)} siap dikembangkan.')">+ Tambah Data</button></div>`;$$(".portTab").forEach(b=>b.onclick=()=>show(b.dataset.tab));show("Profil")}
    function renderModule(title,items){$("#page").innerHTML=`<div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">Modul SIBAKTI</p><h2 class="mt-1 text-3xl font-black">${esc(title)}</h2><p class="mt-1 text-slate-500">Fitur siap dikembangkan ke CRUD Spreadsheet.</p></div><div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">${items.map(x=>`<div class="rounded-[2rem] bg-white p-6 shadow-soft"><h3 class="text-xl font-black">${esc(x)}</h3><p class="mt-2 text-sm text-slate-500">Modul ${esc(x)}.</p><button class="mt-5 rounded-2xl border px-4 py-2 font-black" onclick="toast('Modul ${esc(x)} siap dihubungkan ke backend.')">Buka</button></div>`).join("")}</div>`}
    function renderStudentHome(){$("#page").innerHTML=`<div class="rounded-[2rem] theme-dark p-6 text-white shadow-soft md:p-8"><p class="text-sm font-bold uppercase tracking-[.25em] text-yellow-200">Beranda Siswa</p><h2 class="mt-3 text-3xl font-black md:text-5xl">Halo, ${esc(state.user?.Nama||"Siswa")}</h2><p class="mt-4 text-emerald-50">Lengkapi portofolio, asesmen, prestasi, sertifikat, karya, rencana studi lanjut, dan karier.</p></div>`}
    function renderRecommendation(){$("#page").innerHTML=`<div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">Rekomendasi</p><h2 class="mt-1 text-3xl font-black">Rekomendasi Guru BK</h2><p class="mt-1 text-slate-500">Rekomendasi layanan, belajar, studi lanjut, dan karier.</p></div><div class="mt-6 rounded-[2rem] bg-white p-6 shadow-soft text-sm text-slate-500">Belum ada rekomendasi.</div>`}
    function renderSettings(){const isSuper=role()==="SUPERADMIN";$("#page").innerHTML=`<div><p class="text-sm font-black uppercase tracking-[.2em] text-primary">Pengaturan</p><h2 class="mt-1 text-3xl font-black">${isSuper?"Pengaturan Sistem Nasional":role()==="GURU_BK"?"Pengaturan Guru BK":"Pengaturan Akun"}</h2><p class="mt-1 text-slate-500">Kelola preferensi aplikasi sesuai role.</p></div>${isSuper?appearanceForm():""}<div class="mt-6 grid gap-6 xl:grid-cols-[280px_1fr]"><div class="rounded-[2rem] bg-white p-4 shadow-soft">${["Profil Akun","Profil Madrasah","Template Dokumen","Import Excel","Export Data","Keamanan"].map((x,i)=>`<button data-section="${i}" class="setBtn w-full rounded-2xl px-4 py-3 text-left font-black ${i===0?"bg-emerald-50 text-emerald-700":"hover:bg-slate-50"}">${x}</button>`).join("")}</div><div id="settingsEditor" class="rounded-[2rem] bg-white p-6 shadow-soft"></div></div>`;if(isSuper)setupAppearanceForm();$$(".setBtn").forEach(b=>b.onclick=()=>openSetting(Number(b.dataset.section)));openSetting(0)}
    function openSetting(i){$$(".setBtn").forEach((b,idx)=>{b.classList.toggle("bg-emerald-50",idx===i);b.classList.toggle("text-emerald-700",idx===i)});const titles=["Profil Akun","Profil Madrasah","Template Dokumen","Import Excel","Export Data","Keamanan"];if(i===0){$("#settingsEditor").innerHTML=`<h3 class="text-2xl font-black">Profil Akun</h3><form id="profileForm" class="mt-6 grid gap-4 md:grid-cols-2"><label class="md:col-span-2"><span class="text-sm font-bold">Nama Lengkap</span><input name="Nama" value="${esc(state.user?.Nama||"")}" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><label><span class="text-sm font-bold">Email</span><input name="Email" value="${esc(state.user?.Email||"")}" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><label><span class="text-sm font-bold">No HP</span><input name="NoHP" value="${esc(state.user?.NoHP||"")}" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><div class="md:col-span-2 flex justify-end"><button class="rounded-2xl theme-primary px-5 py-3 font-black text-white">Simpan Profil</button></div></form>`;$("#profileForm").onsubmit=async e=>{e.preventDefault();try{loading(true);const r=await api("saveOwnProfile",formObj(e.target));toast(r.message||"Profil disimpan");state.user={...state.user,...formObj(e.target)};$("#userInfo").textContent=`${state.user.Nama} • ${role()} • ${state.user.Madrasah||"-"}`}catch(er){toast(er.message||"Backend saveOwnProfile belum dipasang.")}finally{loading(false)}}}else if(i===5){$("#settingsEditor").innerHTML=`<h3 class="text-2xl font-black">Keamanan</h3><form id="passForm" class="mt-6 grid gap-4 md:grid-cols-2"><label class="md:col-span-2"><span class="text-sm font-bold">Password Saat Ini</span><input name="currentPassword" type="password" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><label><span class="text-sm font-bold">Password Baru</span><input name="newPassword" type="password" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><label><span class="text-sm font-bold">Konfirmasi Password</span><input name="confirmPassword" type="password" class="mt-1 w-full rounded-2xl border px-4 py-3"></label><div class="md:col-span-2 flex justify-end"><button class="rounded-2xl theme-primary px-5 py-3 font-black text-white">Ubah Password</button></div></form>`;$("#passForm").onsubmit=async e=>{e.preventDefault();const d=formObj(e.target);if(d.newPassword!==d.confirmPassword)return toast("Konfirmasi password tidak sama.");try{loading(true);const r=await api("changeMyPassword",d);toast(r.message||"Password diubah");e.target.reset()}catch(er){toast(er.message||"Backend changeMyPassword belum dipasang.")}finally{loading(false)}}}else{$("#settingsEditor").innerHTML=`<h3 class="text-2xl font-black">${titles[i]}</h3><p class="mt-2 text-sm text-slate-500">Form ${titles[i]} siap dikembangkan dan dihubungkan ke backend.</p><div class="mt-6 rounded-2xl bg-slate-50 p-5 text-sm text-slate-500">Klik modul ini untuk pengembangan lanjutan.</div>`}}
    function appearanceForm(){const a=state.appearance;return`<div class="mt-6 rounded-[2rem] border-2 border-yellow-300/40 bg-white p-6 shadow-soft"><div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-yellow-700">Khusus Superadmin</p><h3 class="mt-1 text-2xl font-black">Edit Background dan Tampilan Nasional</h3><p class="mt-1 text-sm text-slate-500">Berlaku untuk semua pengguna.</p></div><button id="resetAppearanceBtn" class="rounded-2xl border px-4 py-2 font-black">Reset Kemenag</button></div><form id="appearanceForm" class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4"><input name="appName" value="${esc(a.appName)}" class="xl:col-span-2 rounded-2xl border px-4 py-3" placeholder="Nama Aplikasi"><input name="loginSubtitle" value="${esc(a.loginSubtitle)}" class="xl:col-span-2 rounded-2xl border px-4 py-3" placeholder="Subjudul"><input name="primaryColor" type="color" value="${esc(a.primaryColor)}" class="h-12 rounded-2xl border px-2 py-1"><input name="secondaryColor" type="color" value="${esc(a.secondaryColor)}" class="h-12 rounded-2xl border px-2 py-1"><input name="accentColor" type="color" value="${esc(a.accentColor)}" class="h-12 rounded-2xl border px-2 py-1"><select name="backgroundMode" class="rounded-2xl border px-4 py-3"><option value="gradient" ${a.backgroundMode==="gradient"?"selected":""}>Gradient Kemenag</option><option value="image" ${a.backgroundMode==="image"?"selected":""}>Gambar URL</option></select><input name="backgroundImageUrl" value="${esc(a.backgroundImageUrl||"")}" placeholder="URL gambar background" class="xl:col-span-3 rounded-2xl border px-4 py-3"><input name="overlayOpacity" type="number" min="0" max="1" step="0.05" value="${esc(a.overlayOpacity)}" class="rounded-2xl border px-4 py-3"><div class="xl:col-span-4 flex justify-end gap-3"><button type="button" id="previewAppearanceBtn" class="rounded-2xl border px-5 py-3 font-black">Preview</button><button class="rounded-2xl theme-primary px-5 py-3 font-black text-white">Simpan untuk Semua Pengguna</button></div></form></div>`}
    function setupAppearanceForm(){$("#previewAppearanceBtn").onclick=()=>{const d=formObj($("#appearanceForm"));d.overlayOpacity=Number(d.overlayOpacity||.82);applyAppearance({...state.appearance,...d});toast("Preview diterapkan sementara.")};$("#resetAppearanceBtn").onclick=()=>{applyAppearance(DEFAULT_APPEARANCE);renderSettings();toast("Tema Kemenag default diterapkan. Klik Simpan untuk permanen.")};$("#appearanceForm").onsubmit=async e=>{e.preventDefault();try{loading(true);const d=formObj(e.target);d.overlayOpacity=Number(d.overlayOpacity||.82);const r=await api("saveAppAppearance",d);applyAppearance(r.appearance||d);toast(r.message||"Tampilan nasional disimpan.")}catch(er){toast(er.message)}finally{loading(false)}}}
    function openStudentModal(row={}){const f=$("#studentForm");f.reset();Object.keys(row).forEach(k=>{if(f.elements[k])f.elements[k].value=row[k]||""});if(!f.elements.Madrasah.value&&state.user)f.elements.Madrasah.value=state.user.Madrasah||"";$("#studentModal").classList.remove("hidden")}function closeStudentModal(){$("#studentModal").classList.add("hidden")}
    async function bootstrap(){await loadAppearance();if(!state.token)return showAuth();try{loading(true);const r=await api("currentUser");state.user=r.user;showApp();setPage(role()==="SISWA"?"studentHome":"dashboard")}catch(e){localStorage.removeItem("sibakti_token");state.token="";state.user=null;showAuth()}finally{loading(false)}}
    $("#loginForm").onsubmit=async e=>{e.preventDefault();try{loading(true);const r=await api("loginUser",formObj(e.target));state.token=r.token;state.user=r.user;localStorage.setItem("sibakti_token",state.token);showApp();setPage(role()==="SISWA"?"studentHome":"dashboard");toast("Login berhasil.")}catch(er){toast(er.message)}finally{loading(false)}};
    $("#registerForm").onsubmit=async e=>{e.preventDefault();try{loading(true);const r=await api("registerUser",formObj(e.target));toast(r.message);$("#registerPanel").classList.add("hidden-view");$("#loginPanel").classList.remove("hidden-view");e.target.reset()}catch(er){toast(er.message)}finally{loading(false)}};
    $("#logoutBtn").onclick=async()=>{try{loading(true);await api("logoutUser")}catch(e){}finally{localStorage.removeItem("sibakti_token");state.token="";state.user=null;loading(false);showAuth()}};
    $("#studentForm").onsubmit=async e=>{e.preventDefault();try{const d=formObj(e.target);if(!/^[0-9]{10}$/.test(d.NISN||""))throw new Error("NISN harus 10 digit angka.");loading(true);const r=await api("saveStudent",d);toast(r.message);closeStudentModal();renderStudents()}catch(er){toast(er.message)}finally{loading(false)}};
    $("#goRegisterBtn").onclick=()=>{$("#loginPanel").classList.add("hidden-view");$("#registerPanel").classList.remove("hidden-view")};$("#goLoginBtn").onclick=()=>{$("#registerPanel").classList.add("hidden-view");$("#loginPanel").classList.remove("hidden-view")};$("#menuBtn").onclick=()=>$("#sidebar").classList.toggle("-translate-x-full");$("#refreshBtn").onclick=()=>setPage(state.currentPage);$("#closeStudentModalBtn").onclick=closeStudentModal;$("#cancelStudentBtn").onclick=closeStudentModal;
    bootstrap();
  </script>
